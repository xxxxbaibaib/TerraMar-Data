# 复制为 `.env` 并填写。不要将含真实密钥的 `.env` 提交到 Git。

# Supabase（必填以连接云端）
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Geoapify Places API（可选）：周边地图兴趣点优先走 Geoapify，失败回退 Overpass
# VITE_GEOAPIFY_API_KEY=
# 可选，默认 https://api.geoapify.com/v2/places（无 query 参数）
# VITE_GEOAPIFY_PLACES_BASE_URL=

# VITE_USE_MOCK_AUTH=true
